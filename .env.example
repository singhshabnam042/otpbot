# Copy this file to .env and fill in your actual values
# cp .env.example .env

# ─────────────────────────────────────────
# Telegram Bot Token — Get from @BotFather
# ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ─────────────────────────────────────────
# 5sim.net API Key — Get from https://5sim.net profile page
# ─────────────────────────────────────────
FIVESIM_API_KEY=your-5sim-api-key-here

# ─────────────────────────────────────────
# Settings (optional — defaults shown)
# ─────────────────────────────────────────

# Maximum price per number in cents (15 = $0.15)
MAX_PRICE=15

# Minimum stock count required to consider a country/operator
MIN_STOCK=10

# OTP polling interval in seconds
POLL_INTERVAL=5

# OTP wait timeout in seconds (120 = 2 minutes)
OTP_TIMEOUT=120

# Maximum buy retries (tries next cheapest country on failure)
MAX_RETRIES=3

# Comma-separated Telegram user IDs allowed to use the bot (blank = anyone)
# Example: ADMIN_USER_IDS=123456789,987654321
ADMIN_USER_IDS=
